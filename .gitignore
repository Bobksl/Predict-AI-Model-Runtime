# ---- Data (large; downloaded separately, never committed) ----
/data/
*.npz
*.zip

# ---- Caches & generated artifacts ----
cache/
.cache/
artifacts/checkpoints/
artifacts/submissions/
artifacts/figures/*.png
*.parquet

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.venv/
venv/

# ---- OS / editor / local-only config ----
.DS_Store
Thumbs.db
.claude/settings.local.json

# Keep empty scaffold dirs
!**/.gitkeep
artifacts/*.log

# downloaded kernel outputs (never commit)
artifacts/kaggle_out*/
artifacts/kaggle_v2/
artifacts/kernel_meta/

# ---- Internal-only (kept on disk, not in the public repo) ----
docs/
.claude/
PROGRESS.MD
SETUP.MD
archive/
kaggle_p4/
